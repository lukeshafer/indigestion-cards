---
import { PageTitle } from '@admin/components/text';
import Page from '@admin/layouts/Page.astro';
import { getAllPackTypes } from '@core/lib/pack-type';
import { BatchPackForm } from '@admin/components/pack/BatchPackForm';

const packTypes = await getAllPackTypes();
---

<Page title="Give Pack">
	<PageTitle>Give Pack</PageTitle>
	<section>
		<BatchPackForm packTypes={packTypes} client:load />
	</section>
</Page>
