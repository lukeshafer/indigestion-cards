---
import Base from '@/layouts/Base.astro';
import { getAllCardDesigns } from '@lib/design';
import CardPage, { route } from '@/routes/card';
import Router from '@/router';
import { getSiteConfig } from '@lil-indigestion-cards/core/lib/site-config';

const designs = await getAllCardDesigns();
const siteConfig = await getSiteConfig();
---

<Base title="All Cards" pageType="public">
	<Router
		ssrUrl={Astro.url.pathname}
		ssrComponent={CardPage}
    ssrRoute={route}
		ssrData={{ designs }}
		siteConfig={siteConfig}
		session={Astro.locals.session}
		client:load
	/>
</Base>
