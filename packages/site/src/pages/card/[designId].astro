---
import Page from '@/layouts/Page.astro';
import { getCardDesignAndOpenedInstances } from '@lib/design';
import { getRarityRanking, getSiteConfig } from '@lib/site-config';
import { routes, routeNames } from '@/constants';
import CardDesignPage from '@/routes/card/[designId]';
import Router from '@/data/router';

const designId = Astro.params.designId;

if (!designId) {
	return Astro.redirect(routes.DESIGNS + '?alert=No design id provided');
}

const card = await getCardDesignAndOpenedInstances({ designId, });
console.log(card)

if (!card.design) {
	return Astro.redirect(`${routes.DESIGNS}?error=Design ${designId} not found`);
}

const siteConfig = await getSiteConfig();
const rarityRanking = getRarityRanking(siteConfig);
---

<Page
	title={`${card.design.cardName} - ${card.design.seasonName}`}
	class="flex flex-col gap-9"
	pageType="public"
	breadcrumbs={[{ label: routeNames.CARDS, href: routes.DESIGNS }, { label: card.design.cardName }]}>
  <Router
    ssrUrl={Astro.url.pathname}
    ssrComponent={CardDesignPage}
    ssrData={{ card, siteConfig, rarityRanking }}
    session={Astro.locals.session}
    client:load
    />
</Page>
