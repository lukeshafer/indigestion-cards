---
import Page from '@/layouts/Page.astro';
import { getAllPreorders } from '@lib/preorder';
import { routeNames } from '@/constants';
import UsersPage from '@/routes/user/index';
import Router from '@/router';

import { getAllUsersSortedByName } from '@lil-indigestion-cards/core/lib/user';

const users = await getAllUsersSortedByName();
const preorders = await getAllPreorders();
---

<Page title="Users" breadcrumbs={[{ label: routeNames.USER }]} pageType="public">
  <Router
    ssrUrl={Astro.url.pathname}
    ssrComponent={UsersPage}
    ssrData={{ users, preorders }}
    session={Astro.locals.session}
    client:load
  />
</Page>
