---
import Router from '@/components/router/client-router';
import Base from '@/layouts/Base.astro';
import { routes } from '@/routes';
import { server } from '@/data.server';

const route = await server.loadServerRoute({
  routes,
	url: Astro.url,
});

console.log("Loaded Route", { route })
---

<Base title="New Homepage Test" pageType="public">
	<Router
		ssrUrl={Astro.url.pathname}
		ssrCtx={{
			session: Astro.locals.session,
			disableAnimations: Astro.cookies.get('disable-animations')?.boolean() ?? false,
		}}
    ssrRoute={route}
		client:load
	/>
</Base>
