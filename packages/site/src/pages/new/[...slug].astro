---
import Page from '@/layouts/Page.astro';
import Router from '@/components/router/client-router';
---

<Page title="testing">
	<Router
		ssrUrl={Astro.url.pathname}
		ssrCtx={{
			session: Astro.locals.session,
			disableAnimations: Astro.cookies.get('disable-animations')?.boolean() ?? false,
		}}
		client:load
	/>
</Page>
