---
import { getSiteConfig } from '@lil-indigestion-cards/core/lib/site-config';
import IndexPage, { route } from '@/routes/index';
import Router from '@/router';
import Base from '@/layouts/Base.astro';

const siteConfig = await getSiteConfig();
---

<Base title="Indigestion Cards" pageType="public">
	<Router
    title="Indigestion Cards"
		ssrUrl={Astro.url.pathname}
    ssrComponent={IndexPage}
    ssrRoute={route}
    ssrData={{ siteConfig }}
    siteConfig={siteConfig}
    session={Astro.locals.session}
		client:load
	/>
</Base>
